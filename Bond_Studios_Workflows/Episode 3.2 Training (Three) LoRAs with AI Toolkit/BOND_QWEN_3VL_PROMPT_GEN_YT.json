 output into two sections:\nStage 1 – describe the first half of the video.\nStage 2 – describe the second half of the video.\n\nFor each stage, write a natural paragraph (no more than 80 words per stage) that smoothly incorporates the subject, scene, action, and important details.\nDo not use labels like 'Subject:', 'Scene:', 'Action:', or 'Details:'.\nOnly output the two stages in your reply in this format:\n\nStage 1 – [natural descriptive paragraph]\nStage 2 – [natural descriptive paragraph]\n\nRespond with text only.",1024,0.6,0.9,1,1.2,16,true,3292916945,"randomize"],"color":"#28403f","bgcolor":"#374539"},{"id":41,"type":"Label (rgthree)","pos":[1229.7839876292626,-1934.4134207852767],"size":[518.3544921875,106],"flags":{"allow_interaction":true},"order":13,"mode":0,"inputs":[],"outputs":[],"title":"QWEN3VL","properties":{"fontSize":106,"fontFamily":"Arial","fontColor":"#999999","textAlign":"left","backgroundColor":"transparent","padding":0,"borderRadius":0,"angle":0,"ue_properties":{"widget_ue_connectable":{},"version":"7.4","input_ue_unconnectable":{}}},"color":"#fff0","bgcolor":"#fff0"},{"id":88,"type":"Label (rgthree)","pos":[3194.2788416900503,-1614.735077224779],"size":[197.81494140625,35],"flags":{"allow_interaction":true},"order":14,"mode":0,"inputs":[],"outputs":[],"title":"Node Values","properties":{"fontSize":35,"fontFamily":"Arial","fontColor":"#999999","textAlign":"left","backgroundColor":"transparent","padding":0,"borderRadius":0,"angle":0,"ue_properties":{"widget_ue_connectable":{},"version":"7.4","input_ue_unconnectable":{}}},"color":"#fff0","bgcolor":"#fff0"},{"id":87,"type":"Label (rgthree)","pos":[3191.930700419204,-1664.8494332628145],"size":[461.3525390625,50],"flags":{"allow_interaction":true},"order":15,"mode":0,"inputs":[],"outputs":[],"title":"QwenVL (Advanced)","properties":{"fontSize":50,"fontFamily":"Arial","fontColor":"#999999","textAlign":"left","backgroundColor":"transparent","padding":0,"borderRadius":0,"angle":0,"ue_properties"